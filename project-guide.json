{
  "name": "Vendora Marketplace",
  "description": "Full-stack marketplace with React, Tailwind, and Supabase",
  "setupSteps": [
    {
      "step": 1,
      "title": "Create Supabase Project",
      "actions": [
        "Go to https://supabase.com",
        "Create a new project",
        "Wait for project to initialize"
      ]
    },
    {
      "step": 2,
      "title": "Get Supabase Keys",
      "actions": [
        "Go to Settings → API",
        "Copy Project URL",
        "Copy anon/public key"
      ]
    },
    {
      "step": 3,
      "title": "Setup Database",
      "actions": [
        "Go to SQL Editor in Supabase",
        "Run the SQL from supabase_schema.sql",
        "Verify all tables created"
      ]
    },
    {
      "step": 4,
      "title": "Setup Storage",
      "actions": [
        "Go to Storage in Supabase",
        "Create 'products' bucket",
        "Make bucket public",
        "Add upload policies"
      ]
    },
    {
      "step": 5,
      "title": "Setup Authentication",
      "actions": [
        "Go to Authentication → Providers",
        "Enable Email/Password",
        "Enable Google OAuth (optional)",
        "Configure redirect URLs"
      ]
    },
    {
      "step": 6,
      "title": "Get Paystack Keys",
      "actions": [
        "Go to https://paystack.com",
        "Create account and verify",
        "Go to Settings → API Keys",
        "Copy Public Key (use test key for dev)"
      ]
    },
    {
      "step": 7,
      "title": "Configure Environment",
      "actions": [
        "Copy .env.example to .env",
        "Add your Supabase URL",
        "Add your Supabase anon key",
        "Add your Paystack public key"
      ]
    },
    {
      "step": 8,
      "title": "Install & Run",
      "actions": [
        "Run: pnpm install",
        "Run: pnpm run dev",
        "Open browser to localhost"
      ]
    },
    {
      "step": 9,
      "title": "Create Admin Account",
      "actions": [
        "Sign up through the UI",
        "Go to Supabase SQL Editor",
        "Update your user role to 'admin' and verified to true"
      ]
    },
    {
      "step": 10,
      "title": "Test Everything",
      "actions": [
        "Create a seller account",
        "Verify seller as admin",
        "Add test products",
        "Test all features"
      ]
    }
  ],
  "commonIssues": [
    {
      "issue": "CORS errors",
      "solution": "Add your URL to Supabase allowed origins"
    },
    {
      "issue": "Images not uploading",
      "solution": "Ensure products bucket exists and is public"
    },
    {
      "issue": "Products not showing",
      "solution": "Verify seller is marked as verified in database"
    },
    {
      "issue": "Authentication failing",
      "solution": "Check redirect URLs in Supabase settings"
    }
  ],
  "keyFeatures": {
    "authentication": [
      "Email/Password",
      "Google OAuth",
      "Magic Link"
    ],
    "userRoles": [
      "Buyer - Browse and purchase",
      "Seller - List products (after verification)",
      "Admin - Verify sellers and manage platform"
    ],
    "marketplace": [
      "Product listings with images",
      "Category filtering",
      "Search functionality",
      "Wishlist",
      "Messaging",
      "Seller profiles"
    ],
    "payments": [
      "Paystack integration",
      "80/20 revenue split (seller/platform)",
      "Transaction tracking"
    ],
    "boosting": [
      "3 pricing tiers",
      "Auto-expiry",
      "Priority placement",
      "100% platform revenue"
    ]
  },
  "productionChecklist": [
    "Switch to production Supabase keys",
    "Switch to live Paystack keys",
    "Enable RLS on all tables",
    "Set up Paystack webhooks",
    "Add custom domain",
    "Enable HTTPS",
    "Set up backups",
    "Add monitoring"
  ]
}
